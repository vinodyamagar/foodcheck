# Server port (Render provides PORT automatically)
PORT=3001

# Text generation model to use
MODEL_ID=Xenova/distilgpt2

# Prefer Hugging Face Inference API in hosted envs
USE_HF_INFERENCE=1

# Hugging Face token (set in platform secret manager)
HUGGINGFACE_API_TOKEN=

# Allowed origin for CORS in production
# Example: https://your-project.vercel.app
CORS_ORIGIN=
